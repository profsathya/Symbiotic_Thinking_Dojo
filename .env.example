# This file serves as an example for the required environment variables.
# To get started, create a new file named `.env.local` in the project root
# and add your API keys below.

# The key for the Anthropic (Claude) API.
# The default model, Claude 3 Opus, uses this key.
# Get one from: https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# The key for the Google (Gemini) API.
# Required to use any of the Gemini models.
# Get one from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# The key for the OpenAI (GPT) API.
# Required to use any of the GPT models.
# Get one from: https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# Commons Chat API — shared backend for "The Commons" partner platform.
# The endpoint at /api/chat/commons is gated by a Bearer token and is NOT
# meant for direct use by dojo visitors.
#
# - NEXT_PUBLIC_COMMONS_ENABLED: set to "true" to show Commons as a provider
#   option in the dojo's UI. Leave unset/false to hide it. The endpoint
#   itself remains callable for authorized clients regardless of this flag.
# - COMMONS_API_KEY: server-side Anthropic/Gemini key used to answer requests.
# - COMMONS_AUTH_TOKEN: shared secret that clients must send as
#   `Authorization: Bearer <token>`. Generate with `openssl rand -hex 32`.
#   If this is unset, the endpoint returns 503 for all requests (fail-closed).
# - COMMONS_PROVIDER: "gemini" (default) or "anthropic".
NEXT_PUBLIC_COMMONS_ENABLED="false"
COMMONS_API_KEY=""
COMMONS_AUTH_TOKEN=""
COMMONS_PROVIDER="gemini"
COMMONS_MODEL="gemini-2.5-flash"