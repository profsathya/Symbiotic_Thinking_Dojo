# This file serves as an example for the required environment variables.
# To get started, create a new file named `.env.local` in the project root
# and add your API keys below.

# The key for the Anthropic (Claude) API.
# The default model, Claude 3 Opus, uses this key.
# Get one from: https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# The key for the Google (Gemini) API.
# Required to use any of the Gemini models.
# Get one from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# The key for the OpenAI (GPT) API.
# Required to use any of the GPT models.
# Get one from: https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# Commons Chat API — shared, key-free access for all users.
# Set NEXT_PUBLIC_COMMONS_ENABLED=true to show Commons as a provider option.
# COMMONS_API_KEY is the server-side key used by the Commons endpoint.
# COMMONS_PROVIDER can be "gemini" (default) or "anthropic".
NEXT_PUBLIC_COMMONS_ENABLED="false"
COMMONS_API_KEY=""
COMMONS_PROVIDER="gemini"
COMMONS_MODEL="gemini-2.5-flash"